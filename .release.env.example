# Copy this file to .release.env and fill in your tokens.
# .release.env is git-ignored and is loaded by release_extension.ps1.

# Open VSX personal access token (https://open-vsx.org)
OVSX_PAT=

# VS Code Marketplace personal access token (used by vsce publish)
VSCE_PAT=

# Website deploy target (used by deploy_website.ps1). Not confidential per se,
# but kept out of git and the VSIX so the server address is not published.
WEB_DEPLOY_HOST=
WEB_DEPLOY_USER=
WEB_DEPLOY_PATH=
WEB_URL=
